---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

const description =
  "Meet the skilled and experienced team behind our platform";

// Team images
import p1 from "../../assets/team/t1.png";
import p2 from "../../assets/team/t2.png";

const team = [
  {
    pic: p1,
    name: "Abdu Nur Ilham",
    role: "Marketing Lead",
    description:
      "Marketing strategy, marketing analysis, copywriting, email marketing/newsletter, social media marketing",
    link: "https://linkedin.com",
  },
  {
    pic: p2,
    name: "Sarah Amalia",
    role: "Technical Support & Operations",
    description:
      "Astro site, troubleshooting, help desk, knowledge base, REST API, SQL, system montoring, ticketing system, information architecture",
    link: "https://sarah-tw.vercel.app/",
  },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="Team" description={description} />
    <div
      class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 grid-rows-2 gap-10"
    >
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
            link={member.link}
          />
        ))
      }
    </div>
  </div>
</Section>
