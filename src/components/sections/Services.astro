---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

const cards = [
  {
    colorIndex: 1,
    titleTop: "Creating Email",
    titleBottom: "in Minutes",
    description: "Build and send professional email campaigns in minutes with our intuitive drag-and-drop editor and pre-built templates.",
  },
  {
    colorIndex: 2,
    titleTop: "Pay-per-click",
    titleBottom: "Advertising",
    description: "Maximize your advertising budget with targeted campaigns that reach the right audience at the right time.",
  },
  {
    colorIndex: 3,
    titleTop: "Social Media",
    titleBottom: "Marketing",
    description: "Build and engage your audience across social media platforms with content creation and community management.",
  },
  {
    colorIndex: 1,
    titleTop: "Email",
    titleBottom: "Marketing",
    description: "Nurture leads and maintain customer relationships through personalized campaigns and automated workflows.",
  },
  {
    colorIndex: 2,
    titleTop: "Content",
    titleBottom: "Creation",
    description: "High-quality content that resonates with your audience — blog posts, articles, ebooks, infographics, and more.",
  },
  {
    colorIndex: 3,
    titleTop: "Analytics and",
    titleBottom: "Tracking",
    description: "Make data-driven decisions with comprehensive tracking, custom dashboards, and actionable performance insights.",
  },
];

const description = "Upcoming";
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle="Services" description={description} />
    <div class="grid lg:grid-cols-2 gap-10">
      {
        cards.map((card) => (
          <ServiceCard
            index={card.colorIndex}
            titleTop={card.titleTop}
            titleBottom={card.titleBottom}
            description={card.description}
          />
        ))
      }
    </div>
  </div>
</Section>