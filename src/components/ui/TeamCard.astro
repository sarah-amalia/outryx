---
import { Image } from "astro:assets";
import linkd from "../../assets/linkedin.svg";
import webIcon from "../../assets/profile-web.svg";
import Card from "./Card.astro";

const { pic, name, role, description, link, website } = Astro.props;
---

<Card isUnderline={true}>
  <div class="p-[60px]">
    <div class="flex flex-col sm:flex-row relative">
      <picture><Image src={pic} alt={name} /></picture>
      <div class="flex flex-col justify-end sm:ml-5">
        <h3 class="text-lg font-medium">{name}</h3>
        <p class="text-sm font-normal">{role}</p>
      </div>
      <div class="absolute right-0 top-0 flex gap-3">
        {website && (
          <a href={website} target="_blank" aria-label="Portfolio website">
            <Image src={webIcon} alt="Website" class="w-8 h-8" />
          </a>
        )}
        {link && (
          <a href={link} target="_blank">
            <Image src={linkd} alt="Linkedin" class="w-8 h-8" />
          </a>
        )}
      </div>
    </div>
    <div class="w-full h-[1px] bg-black my-7"></div>
    <div>{description}</div>
  </div>
</Card>